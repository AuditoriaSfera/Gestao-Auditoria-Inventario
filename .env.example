# ============================================================
# PLATAFORMA SFERA — VARIÁVEIS DE AMBIENTE
# Copie este arquivo para .env e preencha os valores reais
# ============================================================

# Banco de dados PostgreSQL
DATABASE_URL="postgresql://postgres:senha@localhost:5432/sfera_platform"

# Auth Secret — gere com: openssl rand -base64 32
AUTH_SECRET="trocar-por-segredo-forte-em-producao"

# URL base da aplicação
NEXTAUTH_URL="http://localhost:3000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Nome da plataforma (parametrizável)
NEXT_PUBLIC_APP_NAME="Sfera Multifranquias"
NEXT_PUBLIC_APP_LOGO="/icons/logo.svg"

# Redis (para filas de importação)
REDIS_URL="redis://localhost:6379"

# Armazenamento de arquivos
# Opções: "local" | "s3"
STORAGE_PROVIDER="local"
STORAGE_LOCAL_PATH="./uploads"

# S3 (preencher apenas se STORAGE_PROVIDER=s3)
AWS_REGION="us-east-1"
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_S3_BUCKET=""

# E-mail (notificações futuras)
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="noreply@sfera.com.br"

# Log level: trace | debug | info | warn | error
LOG_LEVEL="info"

# Ambiente
NODE_ENV="development"

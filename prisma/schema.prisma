generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

// ============================================================
// ENUMS
// ============================================================



























// ============================================================
// CORE — AUTH & USERS
// ============================================================

model User {
  id                 String     @id @default(cuid())
  name               String
  email              String     @unique
  emailVerified      DateTime?
  passwordHash       String?
  status             String @default("PENDING_ACTIVATION")
  avatarUrl          String?
  phone              String?
  document           String?
  lastLoginAt        DateTime?
  lastLoginIp        String?
  mustChangePassword Boolean    @default(false)
  twoFactorEnabled   Boolean    @default(false)

  roles               UserRole[]
  storeScopes         UserStoreScope[]
  sessions            Session[]
  accounts            Account[]
  auditLogs           AuditLog[]
  activityHistory     ActivityHistory[]
  notifications       Notification[]
  comments            Comment[]           @relation("CommentAuthor")
  attachments         Attachment[]        @relation("AttachmentUploader")
  pendingItems        PendingItem[]       @relation("PendingResponsible")
  pendingInteractions PendingInteraction[]
  importBatches       ImportBatch[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
  createdBy String?
  updatedBy String?

  @@index([email])
  @@index([status])
  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  ipAddress    String?
  userAgent    String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ============================================================
// CORE — RBAC
// ============================================================

model Role {
  id          String   @id @default(cuid())
  name        String   @unique
  label       String
  description String?
  isSystem    Boolean  @default(false)

  permissions RolePermission[]
  users       UserRole[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
  createdBy String?

  @@map("roles")
}

model Permission {
  id          String  @id @default(cuid())
  module      String
  action      String
  scope       String?
  label       String
  description String?

  roles RolePermission[]

  @@unique([module, action, scope])
  @@index([module])
  @@map("permissions")
}

model RolePermission {
  id           String @id @default(cuid())
  roleId       String
  permissionId String

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@map("role_permissions")
}

model UserRole {
  id     String @id @default(cuid())
  userId String
  roleId String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  assignedAt DateTime @default(now())
  assignedBy String?

  @@unique([userId, roleId])
  @@map("user_roles")
}

model UserStoreScope {
  id       String  @id @default(cuid())
  userId   String
  storeId  String?
  groupId  String?
  regionId String?
  scopeAll Boolean @default(false)

  user   User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  store  Store?      @relation(fields: [storeId], references: [id])
  group  StoreGroup? @relation(fields: [groupId], references: [id])
  region Region?     @relation(fields: [regionId], references: [id])

  @@unique([userId, storeId, groupId, regionId])
  @@map("user_store_scopes")
}

// ============================================================
// CORE — ORGANIZATION
// ============================================================

model Region {
  id          String   @id @default(cuid())
  code        String   @unique
  name        String
  description String?
  managerId   String?
  isActive    Boolean  @default(true)

  stores     Store[]
  groups     StoreGroup[]
  userScopes UserStoreScope[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
  createdBy String?

  @@map("regions")
}

model StoreGroup {
  id          String   @id @default(cuid())
  code        String   @unique
  name        String
  description String?
  regionId    String?
  isActive    Boolean  @default(true)

  region     Region?            @relation(fields: [regionId], references: [id])
  members    StoreGroupMember[]
  userScopes UserStoreScope[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
  createdBy String?

  @@map("store_groups")
}

model StoreGroupMember {
  id      String @id @default(cuid())
  groupId String
  storeId String

  group StoreGroup @relation(fields: [groupId], references: [id])
  store Store      @relation(fields: [storeId], references: [id])

  @@unique([groupId, storeId])
  @@map("store_group_members")
}

model Store {
  id        String      @id @default(cuid())
  code      String      @unique
  name      String
  tradeName String?
  cnpj      String?     @unique
  regionId  String?
  status    String @default("ACTIVE")
  address   String?
  city      String?
  state     String?
  zipCode   String?
  phone     String?
  email     String?
  managerId String?
  openedAt  DateTime?
  closedAt  DateTime?
  metadata  String?

  region      Region?            @relation(fields: [regionId], references: [id])
  groups      StoreGroupMember[]
  userScopes  UserStoreScope[]

  cdeRecords       CdeDailyRecord[]
  noteTransits     NoteTransit[]
  writeOffs        WriteOff[]
  conferences      MerchandiseConference[]
  auditRounds      AuditRound[]
  assets           Asset[]
  inventoryCycles  InventoryCycle[]
  pendingItems     PendingItem[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
  createdBy String?

  @@index([code])
  @@index([regionId])
  @@index([status])
  @@map("stores")
}

// ============================================================
// CORE — MASTER DATA
// ============================================================

model ProductCategory {
  id          String   @id @default(cuid())
  code        String   @unique
  name        String
  description String?
  parentId    String?
  isActive    Boolean  @default(true)

  parent   ProductCategory?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children ProductCategory[] @relation("CategoryHierarchy")
  products Product[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@map("product_categories")
}

model Product {
  id          String   @id @default(cuid())
  sku         String   @unique
  barcode     String?
  name        String
  description String?
  categoryId  String?
  supplierId  String?
  unit        String   @default("UN")
  isActive    Boolean  @default(true)
  metadata    String?

  category ProductCategory? @relation(fields: [categoryId], references: [id])
  supplier Supplier?        @relation(fields: [supplierId], references: [id])
  costs    ProductCost[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([sku])
  @@map("products")
}

model ProductCost {
  id         String   @id @default(cuid())
  productId  String
  unitCost   Float
  validFrom  DateTime
  validUntil DateTime?
  createdBy  String?
  source     String?

  product Product @relation(fields: [productId], references: [id])

  createdAt DateTime @default(now())

  @@index([productId, validFrom])
  @@map("product_costs")
}

model Supplier {
  id        String   @id @default(cuid())
  code      String   @unique
  name      String
  tradeName String?
  cnpj      String?  @unique
  email     String?
  phone     String?
  isActive  Boolean  @default(true)

  products     Product[]
  noteTransits NoteTransit[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@map("suppliers")
}

model CostCenter {
  id          String   @id @default(cuid())
  code        String   @unique
  name        String
  description String?
  isActive    Boolean  @default(true)

  auditExpenses  AuditExpense[]
  inventoryCosts InventoryCost[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@map("cost_centers")
}

// ============================================================
// CORE — SYSTEM PARAMETERS
// ============================================================

model SystemParameter {
  id          String   @id @default(cuid())
  key         String   @unique
  value       String
  type        String
  module      String?
  label       String
  description String?
  isPublic    Boolean  @default(false)

  history SystemParameterHistory[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  updatedBy String?

  @@map("system_parameters")
}

model SystemParameterHistory {
  id          String @id @default(cuid())
  parameterId String
  oldValue    String
  newValue    String
  changedBy   String
  reason      String?

  parameter SystemParameter @relation(fields: [parameterId], references: [id])

  createdAt DateTime @default(now())

  @@map("system_parameter_history")
}

// ============================================================
// CORE — ATTACHMENTS & COMMENTS
// ============================================================

model Attachment {
  id              String          @id @default(cuid())
  originalName    String
  storedName      String
  extension       String
  mimeType        String
  fileType        String
  sizeBytes       Int
  fileHash        String
  String String @default("LOCAL")
  storagePath     String
  storageUrl      String?
  module          String
  recordId        String
  description     String?
  uploadedById    String

  uploadedBy User @relation("AttachmentUploader", fields: [uploadedById], references: [id])

  createdAt DateTime  @default(now())
  deletedAt DateTime?

  @@index([module, recordId])
  @@map("attachments")
}

model Comment {
  id         String   @id @default(cuid())
  module     String
  recordId   String
  content    String
  isInternal Boolean  @default(false)
  authorId   String
  parentId   String?

  author  User      @relation("CommentAuthor", fields: [authorId], references: [id])
  parent  Comment?  @relation("CommentReplies", fields: [parentId], references: [id])
  replies Comment[] @relation("CommentReplies")

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([module, recordId])
  @@map("comments")
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  body      String
  type      String
  module    String?
  recordId  String?
  actionUrl String?
  isRead    Boolean  @default(false)
  readAt    DateTime?
  sentAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@map("notifications")
}

model AuditLog {
  id          String   @id @default(cuid())
  userId      String?
  action      String
  module      String?
  recordId    String?
  description String?
  metadata    String?
  ipAddress   String?
  userAgent   String?
  sessionId   String?
  severity    String   @default("INFO")

  user User? @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}

model ActivityHistory {
  id          String         @id @default(cuid())
  module      String
  recordId    String
  action      String
  description String
  fromValue   String?
  toValue     String?
  metadata    String?
  actorId     String

  actor User @relation(fields: [actorId], references: [id])

  createdAt DateTime @default(now())

  @@index([module, recordId])
  @@map("activity_history")
}

// ============================================================
// CORE — PENDING & SLA
// ============================================================

model PendingItem {
  id              String             @id @default(cuid())
  module          String
  recordId        String?
  type            String
  title           String
  description     String
  criticality     String @default("MEDIUM")
  status          String      @default("OPEN")
  origin          String      @default("AUTOMATIC")
  storeId         String?
  regionId        String?
  responsibleId   String?
  slaConfigId     String?
  openedAt        DateTime           @default(now())
  dueAt           DateTime?
  resolvedAt      DateTime?
  closedAt        DateTime?
  expiresAt       DateTime?
  slaBreached     Boolean            @default(false)
  slaBreachedAt   DateTime?
  recurrenceCount Int                @default(0)
  observations    String?
  resolution      String?

  store       Store?     @relation(fields: [storeId], references: [id])
  responsible User?      @relation("PendingResponsible", fields: [responsibleId], references: [id])
  slaConfig   SlaConfig? @relation(fields: [slaConfigId], references: [id])
  interactions PendingInteraction[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
  createdBy String?

  @@index([module, recordId])
  @@index([storeId, status])
  @@index([status, dueAt])
  @@map("pending_items")
}

model PendingInteraction {
  id         String        @id @default(cuid())
  pendingId  String
  type       String
  content    String
  fromStatus String?
  toStatus   String?
  metadata   String?
  authorId   String

  author  User        @relation(fields: [authorId], references: [id])
  pending PendingItem @relation(fields: [pendingId], references: [id])

  createdAt DateTime @default(now())

  @@index([pendingId])
  @@map("pending_interactions")
}

model SlaConfig {
  id               String              @id @default(cuid())
  name             String
  module           String
  type             String?
  criticality      String?
  deadlineHours    Int
  warningHours     Int
  workingHoursOnly Boolean             @default(false)
  isActive         Boolean             @default(true)
  validFrom        DateTime            @default(now())
  validUntil       DateTime?

  pendingItems PendingItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  createdBy String?

  @@unique([module, type, criticality])
  @@map("sla_configs")
}

// ============================================================
// CORE — IMPORTS
// ============================================================

model ImportLayout {
  id          String   @id @default(cuid())
  name        String
  module      String
  description String?
  isActive    Boolean  @default(true)

  versions ImportLayoutVersion[]
  batches  ImportBatch[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
  createdBy String?

  @@unique([module, name])
  @@map("import_layouts")
}

model ImportLayoutVersion {
  id        String   @id @default(cuid())
  layoutId  String
  version   Int
  config    String
  changelog String?
  isActive  Boolean  @default(true)
  publishedAt DateTime?
  publishedBy String?

  layout  ImportLayout @relation(fields: [layoutId], references: [id])
  batches ImportBatch[]

  createdAt DateTime @default(now())
  createdBy String?

  @@unique([layoutId, version])
  @@map("import_layout_versions")
}

model ImportBatch {
  id              String       @id @default(cuid())
  module          String
  fileType        String
  originalName    String
  storedPath      String
  fileHash        String
  fileSize        Int
  status          String @default("UPLOADING")
  layoutId        String?
  layoutVersionId String?
  totalRows       Int          @default(0)
  validRows       Int          @default(0)
  invalidRows     Int          @default(0)
  publishedRows   Int          @default(0)
  uploadedById    String
  errorSummary    String?
  publishedAt     DateTime?
  rolledBackAt    DateTime?

  uploadedBy    User                 @relation(fields: [uploadedById], references: [id])
  layout        ImportLayout?        @relation(fields: [layoutId], references: [id])
  layoutVersion ImportLayoutVersion? @relation(fields: [layoutVersionId], references: [id])
  items         ImportBatchItem[]
  errors        ImportError[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([module, status])
  @@map("import_batches")
}

model ImportBatchItem {
  id          String   @id @default(cuid())
  batchId     String
  rowNumber   Int
  rawData     String
  parsedData  String?
  isValid     Boolean  @default(false)
  isPublished Boolean  @default(false)
  publishedAt DateTime?
  recordId    String?
  businessKey String?
  errors      String?

  batch ImportBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)

  @@index([batchId, isValid])
  @@map("import_batch_items")
}

model ImportError {
  id        String  @id @default(cuid())
  batchId   String
  rowNumber Int?
  field     String?
  errorCode String
  message   String
  rawValue  String?

  batch ImportBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)

  @@index([batchId])
  @@map("import_errors")
}

// ============================================================
// MODULE — CDE
// ============================================================

model CdeDailyRecord {
  id                    String   @id @default(cuid())
  storeId               String
  date                  DateTime
  importBatchId         String?
  initialStock          Float
  entries               Float    @default(0)
  exits                 Float    @default(0)
  sales                 Float    @default(0)
  exchanges             Float    @default(0)
  returns               Float    @default(0)
  finalStock            Float
  theoreticalFinalStock Float
  status                String   @default("PENDING")
  viewedAt              DateTime?
  viewedById            String?
  acceptedAt            DateTime?
  acceptedById          String?
  contestedAt           DateTime?
  contestedById         String?
  contestReason         String?

  store     Store          @relation(fields: [storeId], references: [id])
  movements CdeMovement[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
  createdBy String?
  updatedBy String?

  @@unique([storeId, date])
  @@index([storeId, date])
  @@map("cde_daily_records")
}

model CdeMovement {
  id            String   @id @default(cuid())
  recordId      String
  noteNumber    String?
  type          String
  origin        String?
  destination   String?
  quantity      Float
  value         Float?
  productId     String?
  sku           String?
  description   String?
  responsibleId String?
  occurredAt    DateTime
  metadata      String?

  record CdeDailyRecord @relation(fields: [recordId], references: [id], onDelete: Cascade)

  @@index([recordId])
  @@map("cde_movements")
}

// ============================================================
// MODULE — NOTE TRANSIT
// ============================================================

model NoteTransit {
  id                 String            @id @default(cuid())
  noteNumber         String
  noteType           String
  supplierId         String?
  originStoreId      String?
  destinationStoreId String
  issuedAt           DateTime
  expectedAt         DateTime?
  receivedAt         DateTime?
  status             String @default("PENDING")
  totalValue         Float?
  totalItems         Int               @default(0)
  slaConfigId        String?
  slaBreached        Boolean           @default(false)
  leadTimeHours      Int?
  justification      String?
  importBatchId      String?

  destinationStore Store     @relation(fields: [destinationStoreId], references: [id])
  supplier         Supplier? @relation(fields: [supplierId], references: [id])
  events           NoteTransitEvent[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
  createdBy String?

  @@unique([noteNumber, destinationStoreId])
  @@index([status])
  @@map("note_transits")
}

model NoteTransitEvent {
  id          String   @id @default(cuid())
  transitId   String
  type        String
  description String
  metadata    String?
  actorId     String?

  transit NoteTransit @relation(fields: [transitId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@map("note_transit_events")
}

// ============================================================
// MODULE — WRITE-OFFS
// ============================================================

model WriteOff {
  id            String   @id @default(cuid())
  storeId       String
  importBatchId String?
  date          DateTime
  totalQuantity Float    @default(0)
  totalValue    Float    @default(0)
  totalCost     Float    @default(0)
  status        String   @default("IMPORTED")
  validatedById String?
  validatedAt   DateTime?
  observations  String?

  store Store        @relation(fields: [storeId], references: [id])
  items WriteOffItem[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
  createdBy String?

  @@index([storeId, date])
  @@map("write_offs")
}

model WriteOffItem {
  id          String   @id @default(cuid())
  writeOffId  String
  sku         String
  productId   String?
  description String
  categoryId  String?
  type        String
  quantity    Float
  unitValue   Float?
  totalValue  Float?
  unitCost    Float?
  totalCost   Float?
  reason      String?
  responsibleId String?
  pdv         String?
  metadata    String?

  writeOff WriteOff @relation(fields: [writeOffId], references: [id], onDelete: Cascade)

  @@index([writeOffId])
  @@map("write_off_items")
}

// ============================================================
// MODULE — MERCHANDISE CONFERENCE
// ============================================================

model MerchandiseConference {
  id                      String   @id @default(cuid())
  storeId                 String
  noteNumber              String
  supplierId              String?
  operationType           String
  status                  String   @default("PENDING")
  expectedQty             Float?
  receivedQty             Float?
  conferencedQty          Float?
  shortageQty             Float?
  surplusQty              Float?
  divergenceQty           Float?
  divergenceValue         Float?
  receivedAt              DateTime?
  conferenceStartedAt     DateTime?
  conferenceEndedAt       DateTime?
  systemEntryAt           DateTime?
  receivingTimeMinutes    Int?
  conferenceTimeMinutes   Int?
  totalProcessTimeMinutes Int?
  accuracy                Float?
  responsibleId           String?
  importBatchId           String?
  observations            String?

  store Store                       @relation(fields: [storeId], references: [id])
  items MerchandiseConferenceItem[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
  createdBy String?

  @@index([storeId, status])
  @@map("merchandise_conferences")
}

model MerchandiseConferenceItem {
  id             String  @id @default(cuid())
  conferenceId   String
  sku            String
  productId      String?
  description    String
  expectedQty    Float
  receivedQty    Float   @default(0)
  conferencedQty Float   @default(0)
  divergenceQty  Float   @default(0)
  unitCost       Float?
  divergenceValue Float?
  source         String?
  status         String  @default("OK")

  conference MerchandiseConference @relation(fields: [conferenceId], references: [id], onDelete: Cascade)

  @@map("merchandise_conference_items")
}

// ============================================================
// MODULE — AUDIT ROUND
// ============================================================

model ChecklistTemplate {
  id          String   @id @default(cuid())
  name        String
  description String?
  module      String   @default("audit-round")
  isActive    Boolean  @default(true)

  versions ChecklistVersion[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
  createdBy String?

  @@map("checklist_templates")
}

model ChecklistVersion {
  id          String   @id @default(cuid())
  templateId  String
  version     Int
  label       String?
  isActive    Boolean  @default(true)
  publishedAt DateTime?
  publishedBy String?

  template ChecklistTemplate @relation(fields: [templateId], references: [id])
  items    ChecklistItem[]
  rounds   AuditRound[]

  createdAt DateTime @default(now())
  createdBy String?

  @@unique([templateId, version])
  @@map("checklist_versions")
}

model ChecklistItem {
  id                  String            @id @default(cuid())
  versionId           String
  order               Int
  category            String?
  question            String
  type                String @default("YES_NO")
  options             String?
  weight              Float             @default(1)
  maxScore            Float             @default(1)
  isRequired          Boolean           @default(true)
  requiresEvidence    Boolean           @default(false)
  criticality         String?
  generatePending     Boolean           @default(false)
  pendingTriggerValue String?

  version  ChecklistVersion   @relation(fields: [versionId], references: [id])
  answers  AuditRoundAnswer[]

  @@index([versionId])
  @@map("checklist_items")
}

model AuditRound {
  id                 String           @id @default(cuid())
  storeId            String
  checklistVersionId String
  auditorId          String
  status             String @default("DRAFT")
  scheduledAt        DateTime?
  startedAt          DateTime?
  completedAt        DateTime?
  totalScore         Float?
  maxScore           Float?
  scorePercent       Float?
  observations       String?
  signatureData      String?
  signedAt           DateTime?
  signedById         String?

  store            Store            @relation(fields: [storeId], references: [id])
  checklistVersion ChecklistVersion @relation(fields: [checklistVersionId], references: [id])
  answers          AuditRoundAnswer[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
  createdBy String?

  @@index([storeId, status])
  @@map("audit_rounds")
}

model AuditRoundAnswer {
  id           String   @id @default(cuid())
  roundId      String
  itemId       String
  value        String?
  score        Float?
  observations String?
  isCompliant  Boolean?

  round     AuditRound           @relation(fields: [roundId], references: [id], onDelete: Cascade)
  item      ChecklistItem        @relation(fields: [itemId], references: [id])
  evidences AuditRoundEvidence[]

  @@unique([roundId, itemId])
  @@map("audit_round_answers")
}

model AuditRoundEvidence {
  id           String  @id @default(cuid())
  answerId     String
  attachmentId String
  description  String?

  answer AuditRoundAnswer @relation(fields: [answerId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@map("audit_round_evidences")
}

// ============================================================
// MODULE — AUDIT COST
// ============================================================

model AuditorBaseCost {
  id          String   @id @default(cuid())
  auditorId   String
  monthlyCost Float
  validFrom   DateTime
  validUntil  DateTime?
  notes       String?
  createdBy   String?

  createdAt DateTime @default(now())

  @@index([auditorId, validFrom])
  @@map("auditor_base_costs")
}

model AuditTrip {
  id             String   @id @default(cuid())
  auditorId      String
  collaboratorId String?
  regionId       String?
  description    String?
  stores         String?
  city           String?
  state          String?
  reason         String?
  startDate      DateTime
  endDate        DateTime
  storesCount    Int      @default(0)
  releasedAmount Float    @default(0)
  totalValue     Float    @default(0)
  status         String   @default("OPEN")
  observations   String?
  createdById    String?

  expenses  AuditExpense[]
  formLinks AuditFormLink[]

  collaborator AuditCollaborator? @relation(fields: [collaboratorId], references: [id])

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
  createdBy String?

  @@index([auditorId])
  @@index([collaboratorId])
  @@map("audit_trips")
}

model AuditExpense {
  id              String   @id @default(cuid())
  tripId          String?
  auditorId       String
  collaboratorId  String?
  storeId         String?
  storeName       String?
  cityUf          String?
  costCenterId    String?
  type            String
  subtype         String?
  paymentMethod   String?
  date            DateTime
  value           Float
  description     String?
  attachmentId    String?
  attachmentUrl   String?
  observations    String?

  trip         AuditTrip?         @relation(fields: [tripId], references: [id])
  costCenter   CostCenter?        @relation(fields: [costCenterId], references: [id])
  collaborator AuditCollaborator? @relation(fields: [collaboratorId], references: [id])

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
  createdBy String?

  @@index([auditorId])
  @@index([collaboratorId])
  @@map("audit_expenses")
}

// ============================================================
// MODULE — AUDIT COLLABORATORS & FORMS
// ============================================================

model AuditCollaborator {
  id        String  @id @default(cuid())
  name      String
  role      String?
  phone     String?
  email     String?
  isActive  Boolean @default(true)

  trips     AuditTrip[]
  expenses  AuditExpense[]
  formLinks AuditFormLink[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
  createdBy String?

  @@map("audit_collaborators")
}

model AuditFormLink {
  id             String    @id @default(cuid())
  token          String    @unique @default(cuid())
  collaboratorId String
  tripId         String?
  status         String    @default("NOT_SENT")
  sentAt         DateTime?
  viewedAt       DateTime?
  answeredAt     DateTime?
  expiresAt      DateTime?

  collaborator AuditCollaborator  @relation(fields: [collaboratorId], references: [id])
  trip         AuditTrip?         @relation(fields: [tripId], references: [id])
  response     AuditFormResponse?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
  createdBy String?

  @@index([token])
  @@index([collaboratorId])
  @@map("audit_form_links")
}

model AuditFormResponse {
  id             String   @id @default(cuid())
  formLinkId     String   @unique
  collaboratorId String
  tripId         String?
  storeName      String?
  cityUf         String?
  costCenter     String
  reason         String
  paymentMethod  String
  date           DateTime
  value          Float
  observations   String?
  attachmentUrl  String?

  formLink AuditFormLink @relation(fields: [formLinkId], references: [id])

  createdAt DateTime @default(now())

  @@map("audit_form_responses")
}

// ============================================================
// MODULE — ASSETS
// ============================================================

model Asset {
  id               String      @id @default(cuid())
  assetCode        String      @unique
  description      String
  category         String
  subcategory      String?
  serialNumber     String?
  brand            String?
  model            String?
  storeId          String
  originStoreId    String?
  regionId         String?
  costCenterId     String?
  acquisitionDate  DateTime?
  acquisitionValue Float?
  usefulLifeYears  Int?
  responsibleId    String?
  status           String @default("ACTIVE")
  location         String?
  noteNumber       String?
  supplierId       String?
  metadata         String?
  lastAuditDate    DateTime?
  lastAuditStatus  String?

  store     Store          @relation(fields: [storeId], references: [id])
  movements AssetMovement[]
  audits    AssetAudit[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
  createdBy String?

  @@index([storeId, status])
  @@index([assetCode])
  @@map("assets")
}

model AssetMovement {
  id            String   @id @default(cuid())
  assetId       String
  type          String
  fromStoreId   String?
  toStoreId     String?
  responsibleId String?
  justification String?
  occurredAt    DateTime @default(now())
  approvedById  String?
  approvedAt    DateTime?

  asset Asset @relation(fields: [assetId], references: [id])

  createdAt DateTime @default(now())
  createdBy String?

  @@index([assetId])
  @@map("asset_movements")
}

model AssetAudit {
  id           String   @id @default(cuid())
  assetId      String
  auditorId    String
  storeId      String
  auditDate    DateTime
  found        Boolean
  condition    String?
  location     String?
  observations String?
  attachmentId String?

  asset Asset @relation(fields: [assetId], references: [id])

  createdAt DateTime @default(now())
  createdBy String?

  @@map("asset_audits")
}

// ============================================================
// MODULE — INVENTORY
// ============================================================

model InventoryCycle {
  id            String          @id @default(cuid())
  storeId       String
  cycleNumber   Int
  inventoryType String
  date          DateTime
  period        String?
  status        String @default("AWAITING_IMPORT")
  expectedQty   Float?
  countedQty    Float?
  divergenceQty Float?
  skuCount      Int             @default(0)
  skuDivergence Int             @default(0)
  lossValue     Float?
  gainValue     Float?
  netBalance    Float?
  lossPercent   Float?
  accuracy      Float?
  responsibleId String?
  closedById    String?
  closedAt      DateTime?
  observations  String?

  store    Store              @relation(fields: [storeId], references: [id])
  imports  InventoryImport[]
  items    InventoryItem[]
  closings InventoryClosing[]
  teamKpis InventoryTeamKpi[]
  costs    InventoryCost[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
  createdBy String?
  updatedBy String?

  @@unique([storeId, cycleNumber])
  @@index([storeId, status])
  @@map("inventory_cycles")
}

model InventoryImport {
  id         String   @id @default(cuid())
  cycleId    String
  batchId    String
  importedAt DateTime @default(now())
  importedBy String
  rowCount   Int
  version    Int      @default(1)

  cycle InventoryCycle @relation(fields: [cycleId], references: [id])

  @@map("inventory_imports")
}

model InventoryItem {
  id            String   @id @default(cuid())
  cycleId       String
  sku           String
  productId     String?
  description   String
  categoryId    String?
  expectedQty   Float
  countedQty    Float
  divergenceQty Float
  unitCost      Float?
  lossValue     Float?
  gainValue     Float?
  status        String   @default("OK")
  hasError      Boolean  @default(false)
  errorType     String?

  cycle InventoryCycle @relation(fields: [cycleId], references: [id], onDelete: Cascade)

  @@index([cycleId])
  @@index([sku])
  @@map("inventory_items")
}

model InventoryClosing {
  id                    String   @id @default(cuid())
  cycleId               String
  version               Int      @default(1)
  isOfficial            Boolean  @default(false)
  collaboratorsCount    Int      @default(0)
  collaboratorNames     String?
  startTime             DateTime?
  endTime               DateTime?
  totalDurationMin      Int?
  recountCount          Int      @default(0)
  recountReason         String?
  hadExternalSupport    Boolean  @default(false)
  hadSalesSupport       Boolean  @default(false)
  incidents             String?
  observations          String?
  expectedQty           Float?
  countedQty            Float?
  divergenceQty         Float?
  lossValue             Float?
  gainValue             Float?
  netBalance            Float?
  lossPercent           Float?
  accuracy              Float?
  closedById            String?
  closedAt              DateTime?
  reopenedById          String?
  reopenedAt            DateTime?
  reopenReason          String?

  cycle InventoryCycle @relation(fields: [cycleId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  createdBy String?

  @@unique([cycleId, version])
  @@map("inventory_closings")
}

model InventoryTeamKpi {
  id                    String   @id @default(cuid())
  cycleId               String
  closingVersion        Int
  version               Int      @default(1)
  isOfficial            Boolean  @default(false)
  totalPiecesCounted    Float    @default(0)
  totalSkuCounted       Int      @default(0)
  piecesPerCollaborator Float    @default(0)
  skuPerCollaborator    Float    @default(0)
  productivityPerHour   Float    @default(0)
  totalDurationMin      Int      @default(0)
  piecesByCountError    Float    @default(0)
  skuByCountError       Int      @default(0)
  errorRate             Float    @default(0)
  recountRate           Float    @default(0)
  collaboratorsCount    Int      @default(0)

  cycle   InventoryCycle      @relation(fields: [cycleId], references: [id])
  members InventoryTeamMember[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  createdBy String?

  @@unique([cycleId, version])
  @@map("inventory_team_kpis")
}

model InventoryTeamMember {
  id            String  @id @default(cuid())
  kpiId         String
  name          String
  role          String?
  piecesCount   Float   @default(0)
  skuCount      Int     @default(0)
  isResponsible Boolean @default(false)

  kpi InventoryTeamKpi @relation(fields: [kpiId], references: [id], onDelete: Cascade)

  @@map("inventory_team_members")
}

model InventoryCost {
  id                  String  @id @default(cuid())
  cycleId             String
  costCenterId        String?
  collaboratorsCount  Int     @default(0)
  totalHours          Float   @default(0)
  teamCost            Float   @default(0)
  externalSupportCost Float   @default(0)
  otherCosts          Float   @default(0)
  totalCost           Float   @default(0)
  costPerPiece        Float?
  costPerSku          Float?
  costPerRecount      Float?
  observations        String?

  cycle      InventoryCycle  @relation(fields: [cycleId], references: [id])
  costCenter CostCenter?     @relation(fields: [costCenterId], references: [id])
  items      InventoryCostItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  createdBy String?

  @@map("inventory_costs")
}

model InventoryCostItem {
  id          String  @id @default(cuid())
  costId      String
  description String
  type        String
  value       Float

  cost InventoryCost @relation(fields: [costId], references: [id], onDelete: Cascade)

  @@map("inventory_cost_items")
}
